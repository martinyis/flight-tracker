# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (use ?sslmode=require in production)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# SerpAPI key for flight data
SERPAPI_KEY=

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# Google OAuth client IDs (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Apple App Store Server API (for IAP verification)
APPLE_KEY_ID=
APPLE_ISSUER_ID=
APPLE_BUNDLE_ID=com.martinyis.skylens
# .p8 private key — use ONE of these two options:
# Option A (local dev): path to the .p8 file
APPLE_KEY_PATH=keys/AuthKey.p8
# Option B (Railway/cloud): base64-encoded .p8 contents
#   Generate with: base64 -i keys/YourKey.p8 | tr -d '\n'
# APPLE_PRIVATE_KEY_BASE64=

# ── Optional ──────────────────────────────────────────────────────────────────

# "Sandbox" (default) | "Production" — set to Production for live App Store
APPLE_ENVIRONMENT=Sandbox

# Comma-separated allowed origins (mobile apps typically don't need this)
# CORS_ORIGINS=https://yourdomain.com

# Server port (default: 3000)
# PORT=3000

# "info" (default) | "debug" | "warn" | "error"
# LOG_LEVEL=info

# Set to "production" in production (blocks Xcode IAP bypass, among other things)
# NODE_ENV=production

# Expo push notification access token (avoids rate limits in production)
#   Get one at https://expo.dev/accounts/[you]/settings/access-tokens
# EXPO_ACCESS_TOKEN=
